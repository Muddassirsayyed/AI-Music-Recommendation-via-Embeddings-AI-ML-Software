{
  "name": "musicai-frontend",
  "version": "1.0.0",
  "description": "Modern, professional React UI for AI-powered music discovery",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "axios": "^1.6.2",
    "zustand": "^4.4.5",
